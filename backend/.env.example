# RAG Application Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# GitHub Configuration (REQUIRED)
# ============================================================================

# GitHub Personal Access Token
# Get your token from: https://github.com/settings/tokens
# Required scopes: public_repo, repo (read-only is sufficient)
GITHUB_TOKEN=your_github_token_here

# Default GitHub repository to use
GITHUB_OWNER=fastapi
GITHUB_REPO=fastapi

# Maximum depth for traversing GitHub repo folders
MAX_GITHUB_DEPTH=2

# Folders to skip during GitHub traversal (comma-separated)
# These folders are typically large and not relevant for code search
SKIP_FOLDERS=docs,tests,.github,images,examples,build,dist

# Request timeout for GitHub API calls (seconds)
GITHUB_REQUEST_TIMEOUT=30

# Delay between GitHub API requests (seconds, prevents rate limiting)
GITHUB_REQUEST_DELAY=0.2

# ============================================================================
# Vector Database Configuration (ChromaDB)
# ============================================================================

# Path where embeddings and metadata are stored (on disk)
CHROMA_DB_PATH=chroma_db

# ChromaDB collection name (like a SQL table)
CHROMA_COLLECTION_NAME=repo_chunks

# ============================================================================
# Embeddings Configuration
# ============================================================================

# Model used to convert text to embeddings
# Options:
#   - all-MiniLM-L6-v2 (lightweight, fast, recommended)
#   - all-mpnet-base-v2 (larger, better quality)
#   - paraphrase-MiniLM-L6-v2 (good balance)
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# Dimension of embedding vectors (don't change unless using different model)
EMBEDDINGS_DIMENSION=384

# ============================================================================
# Search Configuration
# ============================================================================

# Number of search results to return by default
SEARCH_RESULTS_COUNT=5

# Similarity threshold (0-1, 0 = no filtering, 1 = exact match only)
# Leave at 0.0 to return all results regardless of similarity
SIMILARITY_THRESHOLD=0.0

# ============================================================================
# FastAPI Configuration
# ============================================================================

# API host (0.0.0.0 = accessible from any IP)
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Auto-reload on code changes (disable in production)
API_RELOAD=True

# ============================================================================
# Code Processing Configuration
# ============================================================================

# Supported file extensions to process (comma-separated)
SUPPORTED_EXTENSIONS=.py

# Maximum file size to process (bytes, default 1MB = 1048576)
MAX_FILE_SIZE=1048576

# Lines per chunk for text-based chunking
CHUNK_SIZE_LINES=50

# Overlapping lines between chunks (for context)
CHUNK_OVERLAP=10

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# Notes
# ============================================================================

# 1. GITHUB_TOKEN is required. Without it, API requests will fail.
#
# 2. Keep your .env file secret! Add to .gitignore (already done)
#
# 3. For security, use environment variables in production instead of .env
#
# 4. The first build takes time (10-30 minutes for large repos)
#    Subsequent runs use cached database
#
# 5. Embeddings model will auto-download on first use (~50MB)
#
# 6. See config.py for all available settings
